# Stage 1: Build
FROM maven:3.8.7-openjdk-18 AS build

ARG GITHUB_TOKEN

# Copy pom and source code
COPY pom.xml /home/app
COPY src /home/app/src

# Clone flyway scripts outside of src
RUN git config --global credential.helper "store --file=/root/.git-credentials" && \
    echo "https://$GITHUB_TOKEN:@github.com" > /root/.git-credentials && \
    git clone https://github.com/mawa-za/flyway-scripts.git /flyway-scripts

# Copy scripts into src/resources/db/migration
RUN mkdir -p /home/app/src/main/resources/db/migration && \
    cp -r /flyway-scripts/* /home/app/src/main/resources/db/migration/

# Build Maven project
RUN mvn -f /home/app/pom.xml clean install -Pdev

# Stage 2: Runtime
FROM openjdk:18-jdk
EXPOSE 8080

ARG JAR_FILE=/home/app/target/mawa-bes.jar
COPY --from=build ${JAR_FILE} app.jar

ENTRYPOINT ["java","-jar","/app.jar"]
