FROM maven:3.8.7-openjdk-18 AS build

# Build arg for GitHub token
ARG GITHUB_TOKEN

# Copy source code
COPY src /home/app/src
COPY pom.xml /home/app

# Configure Git to use token non-interactively
RUN git config --global credential.helper "!f() { echo username=x-access-token; echo password=$GITHUB_TOKEN; }; f" \
    && git clone https://github.com/mawa-za/flyway-scripts.git /home/app/src/main/resources/db/migration

# Build project
RUN mvn -f /home/app/pom.xml clean install -Pdev

# Runtime image
FROM openjdk:latest
EXPOSE 8080
ARG JAR_FILE=/home/app/target/mawa-bes.jar
COPY --from=build ${JAR_FILE} app.jar
ENTRYPOINT ["java","-jar","/app.jar"]
